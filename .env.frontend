# EC2 Instance 3 - Frontend Configuration
# Use this .env file with: docker-compose -f docker-compose.frontend.yml --env-file .env.frontend up -d
# 
# Nginx acts as reverse proxy to private backend
# All API calls to /api/* are automatically routed to the backend in private subnet
# No secrets needed - nginx.conf handles the proxy routing

# Not used - nginx.conf handles backend routing
# VITE_API_URL is set to /api in the Dockerfile
